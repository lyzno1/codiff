#!/bin/sh
set -eu

source_path="$0"

while [ -L "$source_path" ]; do
  source_dir="$(CDPATH= cd -P "$(dirname "$source_path")" >/dev/null 2>&1 && pwd)"
  linked_path="$(readlink "$source_path")"

  case "$linked_path" in
    /*) source_path="$linked_path" ;;
    *) source_path="$source_dir/$linked_path" ;;
  esac
done

script_dir="$(CDPATH= cd -P "$(dirname "$source_path")" >/dev/null 2>&1 && pwd)"
app_path="$(CDPATH= cd -P "$script_dir/../../../.." >/dev/null 2>&1 && pwd)"
repository_path=""
commit_ref=""
walkthrough=0

for arg in "$@"; do
  case "$arg" in
    --walkthrough|-w)
      walkthrough=1
      ;;
    -*)
      ;;
    *)
      if [ -z "$commit_ref" ] && printf '%s' "$arg" | grep -Eq '^[0-9a-fA-F]{4,64}$' && [ ! -e "$arg" ]; then
        commit_ref="$arg"
      elif [ -z "$repository_path" ]; then
        repository_path="$arg"
      fi
      ;;
  esac
done

repository_path="${repository_path:-$PWD}"

if [ -n "$commit_ref" ] && [ "$walkthrough" -eq 1 ]; then
  open -n "$app_path" --args --walkthrough --commit "$commit_ref" "$repository_path"
elif [ -n "$commit_ref" ]; then
  open -n "$app_path" --args --commit "$commit_ref" "$repository_path"
elif [ "$walkthrough" -eq 1 ]; then
  open -n "$app_path" --args --walkthrough "$repository_path"
else
  open -n "$app_path" --args "$repository_path"
fi
